# ============================================================
# Salin file ini menjadi .env dan sesuaikan nilainya
# cp .env.example .env
# ============================================================

# Database
POSTGRES_DB=absensikerja
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ganti_password_anda_disini

# JWT
JWT_SECRET=ganti_dengan_secret_key_acak_64_karakter_hexadecimal
JWT_EXPIRATION_HOUR=24

# JPA DDL: update | validate | none
DDL_AUTO=update
